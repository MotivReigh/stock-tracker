# --- Auth (password gate) ---
APP_PASSWORD=change-me-to-a-long-random-string
AUTH_TOKEN=change-me-to-a-different-long-random-string

# --- Finnhub (quotes, profile, news) ---
# Free tier: https://finnhub.io
FINNHUB_API_KEY=

# --- Twelve Data (daily candles for charts + scans) ---
# Optional but recommended. Free tier (800 req/day, 8 req/min) at https://twelvedata.com
# When unset, candles fall back to Yahoo Finance (no key, but rate-limits per IP).
TWELVE_DATA_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Direct Postgres URL for running migrations from CLI tooling
POSTGRES_URL_NON_POOLING=

# --- Redis (cache) ---
# Either Redis Cloud, Upstash (with TCP URL), or self-hosted
REDIS_URL=

# --- Web Push (VAPID) — generate in Phase 7 ---
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Cron auth ---
CRON_SECRET=change-me-to-a-long-random-string

# --- App URL (for Slack message button targets) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
